# =============================================================================
# Snyk Configuration
# =============================================================================

# API token — get from: Snyk avatar → Account Settings → Auth Token
# Or create a service account: Snyk Org Settings → Service Accounts
SNYK_TOKEN=your_snyk_api_token_here

# Organization ID — get from: Snyk Org Settings → General
# Or via API: curl -H "Authorization: token TOKEN" https://api.snyk.io/rest/orgs?version=2024-10-15
SNYK_ORG_ID=your_snyk_org_id_here

# Optional: Snyk API base URL (only change for non-US regions)
# US (default): https://api.snyk.io
# EU:           https://api.eu.snyk.io
# AU:           https://api.au.snyk.io
# SNYK_BASE_URL=https://api.snyk.io

# =============================================================================
# Jira Server/Data Center Configuration
# =============================================================================

# Your Jira instance URL (no trailing slash)
JIRA_BASE_URL=https://jiraent.example.com

# Personal Access Token — get from: Jira avatar → Profile → Personal Access Tokens
# Needs permissions: view issues, transition issues, reassign issues, add comments
JIRA_PAT=your_jira_personal_access_token_here

# Jira username of the security manager who should close out resolved tickets
# Find via: their Jira profile URL or API: /rest/api/2/user/search?username=name
JIRA_SECURITY_MANAGER_USERNAME=security.manager.username

# Jira status the ticket should move to before reassignment
# Example: In Review
# JIRA_TARGET_STATUS=In Review

# =============================================================================
# Optional Settings
# =============================================================================

# Filter to specific repos (comma-separated). If unset, syncs ALL Snyk projects.
# SNYK_REPO_NAMES=my-repo,another-repo

# Optional: filter Snyk projects by tag or name-prefix (comma-separated)
# Example for HPT repos by name-prefix:
# SNYK_PROJECT_TAGS=project-tag/

# Optional: JQL used to discover Snyk-related Jira tickets
# JIRA_SNYK_JQL=text ~ "SNYK-"

# Optional: local output directory for per-run JSON reports
# SYNC_REPORT_DIR=.local/sync-reports

# Dry run mode — logs what would change without making any modifications
# DRY_RUN=true

# =============================================================================
# Database (only change if not using the included Docker Compose postgres)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/snyk_jira_sync
