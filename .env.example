# Snyk Configuration
SNYK_TOKEN=your_snyk_api_token_here
SNYK_ORG_ID=your_snyk_org_id_here
# Optional: Snyk API base URL (change for non-US regions)
# SNYK_BASE_URL=https://api.snyk.io

# Jira Server/Data Center Configuration
JIRA_BASE_URL=https://jiraent.example.gov
JIRA_PAT=your_jira_personal_access_token_here

# Security Manager - Jira username to reassign resolved tickets to
JIRA_SECURITY_MANAGER_USERNAME=security.manager.username

# Optional: filter by specific repo names (comma-separated)
# SNYK_REPO_NAMES=my-repo,another-repo

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5530/snyk_jira_sync

# Optional: dry run mode - log actions without making changes
# DRY_RUN=true
